{
    "distSpecVersion": "1.0.1",
    "storage": {
        "rootDirectory": "/var/lib/zot"
    },
    "http": {
        "address": "0.0.0.0",
        "port": "5000",
        "accessControl": {
            "repositories": {
                "**": {
                    "anonymousPolicy": ["read", "create"]
                }
            }
        }
    },
    "log": {
        "level": "debug"
    },
    "extensions": {
        "search": {
            "enable": true
        }
    }
}