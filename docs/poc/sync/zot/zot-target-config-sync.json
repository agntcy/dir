{
    "distSpecVersion": "1.0.1",
    "storage": {
        "rootDirectory": "/var/lib/zot"
    },
    "http": {
        "address": "0.0.0.0",
        "port": "5000"
    },
    "log": {
        "level": "info"
    },
    "extensions": {
        "search": {
            "enable": true
        },
        "sync": {
            "enable": true,
            "registries": [
                {
                    "urls": [
                        "http://zot-source:5000"
                    ],
                    "content": [
                        {
                            "prefix": "**",
                            "destination": ""
                        }
                    ],
                    "onDemand": true,
                    "tlsVerify": false
                }
            ]
        }
    }
}