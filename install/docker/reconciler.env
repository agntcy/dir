# Directory Reconciler Configuration
# Environment variable prefix: DIRECTORY (canonical dir config)
# Schema: github.com/agntcy/dir/config.Config

# --- Shared infrastructure -------------------------------------------------
# Used by both the apiserver and the reconciler. Keep these in sync with
# install/docker/apiserver.env so that both services point at the same
# OCI registry and PostgreSQL instance.

# OCI Registry (canonical: registry.*)
DIRECTORY_REGISTRY_REGISTRY_ADDRESS=zot:5000
DIRECTORY_REGISTRY_REPOSITORY_NAME=dir
DIRECTORY_REGISTRY_AUTH_CONFIG_INSECURE=true
DIRECTORY_REGISTRY_AUTH_CONFIG_USERNAME=
DIRECTORY_REGISTRY_AUTH_CONFIG_PASSWORD=

# Database (canonical: database.*)
DIRECTORY_DATABASE_TYPE=postgres
DIRECTORY_DATABASE_POSTGRES_HOST=postgres
DIRECTORY_DATABASE_POSTGRES_PORT=5432
DIRECTORY_DATABASE_POSTGRES_DATABASE=directory
DIRECTORY_DATABASE_POSTGRES_USERNAME=postgres
DIRECTORY_DATABASE_POSTGRES_PASSWORD=postgres
DIRECTORY_DATABASE_POSTGRES_SSL_MODE=disable

# OASF Validation (canonical: oasf_api_validation.*)
DIRECTORY_OASF_API_VALIDATION_SCHEMA_URL=https://schema.oasf.outshift.com

# --- Reconciler tasks ------------------------------------------------------

# Regsync (canonical: reconciler.regsync.*)
# Synchronizes records from remote registries.
DIRECTORY_RECONCILER_REGSYNC_ENABLED=true
DIRECTORY_RECONCILER_REGSYNC_INTERVAL=30s
DIRECTORY_RECONCILER_REGSYNC_TIMEOUT=10m

# Regsync caller authentication (canonical: reconciler.regsync.authn.*)
# Modes: "jwt" or "x509"
DIRECTORY_RECONCILER_REGSYNC_AUTHN_ENABLED=false
DIRECTORY_RECONCILER_REGSYNC_AUTHN_MODE=x509
DIRECTORY_RECONCILER_REGSYNC_AUTHN_SOCKET_PATH=
DIRECTORY_RECONCILER_REGSYNC_AUTHN_AUDIENCES=

# Indexer (canonical: reconciler.indexer.*)
# Indexes records from the local registry into the search database.
DIRECTORY_RECONCILER_INDEXER_ENABLED=true
DIRECTORY_RECONCILER_INDEXER_INTERVAL=30s

# Name task (canonical: reconciler.name.*)
# Re-verifies DNS / name ownership and caches results.
DIRECTORY_RECONCILER_NAME_ENABLED=true
DIRECTORY_RECONCILER_NAME_INTERVAL=1h
DIRECTORY_RECONCILER_NAME_TTL=168h
DIRECTORY_RECONCILER_NAME_RECORD_TIMEOUT=30s

# Signature task (canonical: reconciler.signature.*)
# Verifies record signatures and caches results for the API.
DIRECTORY_RECONCILER_SIGNATURE_ENABLED=true
DIRECTORY_RECONCILER_SIGNATURE_INTERVAL=1m
DIRECTORY_RECONCILER_SIGNATURE_TTL=168h
DIRECTORY_RECONCILER_SIGNATURE_RECORD_TIMEOUT=30s

# Logger output configuration (separate from canonical config.Logging)
# Log levels: DEBUG, INFO, WARN, ERROR. Log formats: json, text.
DIRECTORY_LOGGER_LOG_LEVEL=DEBUG
DIRECTORY_LOGGER_LOG_FORMAT=json
