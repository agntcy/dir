# Directory API Server Configuration
# Environment variable prefix: DIRECTORY (canonical dir config)
# Schema: github.com/agntcy/dir/config.Config

# --- Shared infrastructure -------------------------------------------------
# Used by both the apiserver and the reconciler. Keep these in sync with
# install/docker/reconciler.env so that both services point at the same
# OCI registry and PostgreSQL instance.

# OCI Registry (canonical: registry.*)
DIRECTORY_REGISTRY_LOCAL_DIR=
DIRECTORY_REGISTRY_CACHE_DIR=
DIRECTORY_REGISTRY_REGISTRY_ADDRESS=zot:5000
DIRECTORY_REGISTRY_REPOSITORY_NAME=dir
DIRECTORY_REGISTRY_AUTH_CONFIG_INSECURE=true
DIRECTORY_REGISTRY_AUTH_CONFIG_USERNAME=
DIRECTORY_REGISTRY_AUTH_CONFIG_PASSWORD=
DIRECTORY_REGISTRY_AUTH_CONFIG_ACCESS_TOKEN=
DIRECTORY_REGISTRY_AUTH_CONFIG_REFRESH_TOKEN=

# Database (canonical: database.*)
DIRECTORY_DATABASE_TYPE=postgres
DIRECTORY_DATABASE_POSTGRES_HOST=postgres
DIRECTORY_DATABASE_POSTGRES_PORT=5432
DIRECTORY_DATABASE_POSTGRES_DATABASE=directory
DIRECTORY_DATABASE_POSTGRES_USERNAME=postgres
DIRECTORY_DATABASE_POSTGRES_PASSWORD=postgres
DIRECTORY_DATABASE_POSTGRES_SSL_MODE=disable

# OASF Validation (canonical: oasf_api_validation.*)
DIRECTORY_OASF_API_VALIDATION_SCHEMA_URL=https://schema.oasf.outshift.com

# Logging (canonical: logging.*)
DIRECTORY_LOGGING_VERBOSE=false

# --- Apiserver-specific ----------------------------------------------------

# API listen address (canonical: apiserver.listen_address)
DIRECTORY_APISERVER_LISTEN_ADDRESS=0.0.0.0:8888

# Authentication (canonical: apiserver.authn.*) — modes: "jwt" or "x509"
DIRECTORY_APISERVER_AUTHN_ENABLED=false
DIRECTORY_APISERVER_AUTHN_MODE=x509
DIRECTORY_APISERVER_AUTHN_SOCKET_PATH=
DIRECTORY_APISERVER_AUTHN_AUDIENCES=

# Authorization (canonical: apiserver.authz.*)
DIRECTORY_APISERVER_AUTHZ_ENABLED=false
DIRECTORY_APISERVER_AUTHZ_ENFORCER_POLICY_FILE_PATH=/etc/agntcy/dir/authz_policies.csv

# Routing / P2P (canonical: apiserver.routing.*)
DIRECTORY_APISERVER_ROUTING_LISTEN_ADDRESS=/ip4/0.0.0.0/tcp/8999
DIRECTORY_APISERVER_ROUTING_DIRECTORY_API_ADDRESS=
DIRECTORY_APISERVER_ROUTING_BOOTSTRAP_PEERS=
DIRECTORY_APISERVER_ROUTING_KEY_PATH=
DIRECTORY_APISERVER_ROUTING_DATASTORE_DIR=
DIRECTORY_APISERVER_ROUTING_GOSSIPSUB_ENABLED=true

# Sync (canonical: apiserver.sync.auth_config.*)
DIRECTORY_APISERVER_SYNC_AUTH_CONFIG_USERNAME=
DIRECTORY_APISERVER_SYNC_AUTH_CONFIG_PASSWORD=

# Publication scheduler (canonical: apiserver.publication.*)
DIRECTORY_APISERVER_PUBLICATION_SCHEDULER_INTERVAL=1h
DIRECTORY_APISERVER_PUBLICATION_WORKER_COUNT=1
DIRECTORY_APISERVER_PUBLICATION_WORKER_TIMEOUT=30m

# In-process event bus (canonical: apiserver.events.*)
DIRECTORY_APISERVER_EVENTS_SUBSCRIBER_BUFFER_SIZE=100
DIRECTORY_APISERVER_EVENTS_LOG_SLOW_CONSUMERS=true
DIRECTORY_APISERVER_EVENTS_LOG_PUBLISHED_EVENTS=false

# Prometheus metrics (canonical: apiserver.metrics.*)
DIRECTORY_APISERVER_METRICS_ENABLED=true
DIRECTORY_APISERVER_METRICS_ADDRESS=:9090

# Rate limiting (canonical: apiserver.ratelimit.*)
DIRECTORY_APISERVER_RATELIMIT_ENABLED=false
DIRECTORY_APISERVER_RATELIMIT_GLOBAL_RPS=0
DIRECTORY_APISERVER_RATELIMIT_GLOBAL_BURST=0
DIRECTORY_APISERVER_RATELIMIT_PER_CLIENT_RPS=100
DIRECTORY_APISERVER_RATELIMIT_PER_CLIENT_BURST=200

# Logger output configuration (separate from canonical config.Logging)
# Log levels: DEBUG, INFO, WARN, ERROR. Log formats: json, text.
DIRECTORY_LOGGER_LOG_LEVEL=DEBUG
DIRECTORY_LOGGER_LOG_FORMAT=json
